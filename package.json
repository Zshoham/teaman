{
  "name": "@zshoham/teaman",
  "version": "1.3.0",
  "description": "Static site generator for Obsidian vaults (Astro engine).",
  "type": "module",
  "bin": {
    "teaman": "./bin/teaman.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zshoham/teaman.git"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "resources",
    "slidev-theme-teaman",
    "astro.config.mjs",
    "components.json",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "node bin/teaman.mjs dev ./example",
    "build": "npm run build:all",
    "build:astro": "astro build",
    "preview": "node bin/teaman.mjs preview ./example --out public",
    "build:slides": "node scripts/build-slides.mjs",
    "build:search": "node scripts/build-search.mjs",
    "build:all": "node bin/teaman.mjs build ./example --out public",
    "typecheck": "astro sync && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "node scripts/integration-test.mjs",
    "sync:confluence": "node scripts/sync-confluence.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.3.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@base-ui/react": "^1.5.0",
    "@excalidraw/excalidraw": "0.18.0-063e025",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@myriaddreamin/typst-ts-node-compiler": "^0.7.0",
    "@plantuml/core": "^1.2026.6",
    "@slidev/cli": "^52.17.0",
    "@slidev/theme-default": "^0.25.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "node-tikzjax": "^1.0.5",
    "pagefind": "^1.5.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^2.1.2",
    "rehype-slug": "^6.0.0",
    "remark-wiki-link": "^2.0.1",
    "semver": "^7.8.1",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

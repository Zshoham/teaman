---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Breadcrumbs } from '../../components/Breadcrumbs';
import { fmtDate } from '../../lib/format';
import { readingTimeMeta, wordCount, wordMeta } from '../../lib/text';

export async function getStaticPaths() {
  const notes = await getCollection('notes', n => !n.data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const base = import.meta.env.BASE_URL;
const words = wordCount(note.body ?? '');
---

<Layout title={note.data.title ?? note.id}>
  <article class="mx-auto max-w-[var(--measure)] pt-6 pb-2">
    {/* The section index, not the home feed — the header brand already links
        home, so the crumb is more useful pointing one level up. */}
    <Breadcrumbs segments={[
      { label: 'notes', href: `${base}notes/` },
      { label: note.id },
    ]} />

    <header class="mb-8 border-b border-border pb-6">
      <h1 class="note-title m-0 mb-4 font-serif text-3xl leading-[1.05] font-normal tracking-tight text-balance text-foreground md:text-display">{note.data.title ?? note.id}</h1>
      <div class="note-meta flex flex-wrap items-baseline gap-2 font-mono text-meta text-faint">
        <span>{wordMeta(words)}</span>
        <span class="opacity-50">·</span>
        <span>{readingTimeMeta(words)}</span>
        {note.data.date && <span class="opacity-50">·</span>}
        {note.data.date && <time datetime={note.data.date.toISOString()}>{fmtDate(note.data.date)}</time>}
        {note.data.tags && note.data.tags.length > 0 && (
          <>
            <span class="opacity-50">·</span>
            <span class="inline-flex flex-wrap gap-2">
              {note.data.tags.map(tag => <span class="text-faint tracking-wide">#{tag}</span>)}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';
import { loadAllEntries } from '../lib/entries';
import { fmtDate } from '../lib/format';
import QuickLinks from '../components/home/QuickLinks.astro';
import { FilterBar } from '../components/home/FilterBar';
import { ActiveTagChip } from '../components/home/ActiveTagChip';
import { EntryCard } from '../components/home/EntryCard';
import { TopicsSidebar } from '../components/home/TopicsSidebar';

const entries = await loadAllEntries();

const counts: Record<string, number> = entries.reduce((acc, e) => {
  acc[e.type] = (acc[e.type] ?? 0) + 1;
  return acc;
}, {} as Record<string, number>);

const tagCounts = new Map<string, number>();
entries.forEach(e => e.tags.forEach(t => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)));
const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

const lastUpdated = entries[0]?.updated ?? new Date().toISOString().slice(0, 10);

const filterTabs = [
  { id: 'all', label: 'all', count: entries.length },
  { id: 'note', label: 'notes', count: counts.note ?? 0 },
  { id: 'guide', label: 'guides', count: counts.guide ?? 0 },
  { id: 'slides', label: 'slides', count: counts.slides ?? 0 },
  { id: 'decision', label: 'decisions', count: counts.decision ?? 0 },
].filter(t => t.id === 'all' || t.count > 0);

const footerLeft = `${entries.length} ${entries.length === 1 ? 'entry' : 'entries'} · last edit ${fmtDate(lastUpdated)}`;

const hasSidebar = topics.length > 0;
const quickLinks = SITE_CONFIG.links ?? [];
---

<Layout footerLeft={footerLeft}>
  <h1 class="sr-only">Vault index</h1>
  {quickLinks.length > 0 && (
    <QuickLinks links={quickLinks} />
  )}

  <div
    class:list={[
      'grid gap-10 pt-4',
      hasSidebar ? 'md:grid-cols-[minmax(0,1fr)_240px] md:gap-16' : 'md:grid-cols-1',
    ]}
    data-list-layout
    data-has-sidebar={hasSidebar ? 'true' : 'false'}
  >
    <div>
      <FilterBar filterTabs={filterTabs} />
      <ActiveTagChip />

      <div id="entries" class="flex flex-col scroll-mt-[calc(var(--header-h)_+_4rem)]" data-entries>
        {entries.map(e => <EntryCard entry={e} />)}
      </div>
      <div class="py-10 text-center font-mono text-sm text-faint [&[hidden]]:hidden" data-empty hidden>
        nothing matches.
      </div>
      <button
        type="button"
        class="mx-auto mt-8 block cursor-pointer rounded-md border border-border bg-transparent px-4.5 py-2 font-[inherit] text-meta-lg tabular-nums tracking-wide text-foreground transition-colors hover:border-foreground hover:bg-muted focus-visible:border-foreground focus-visible:bg-muted focus-visible:outline-none [&[hidden]]:hidden"
        data-load-more
        hidden
      >load more</button>
    </div>

    {hasSidebar && <TopicsSidebar topics={topics} client:load />}
  </div>
</Layout>

<script>
  import { createListController } from '../scripts/list-controller';

  const entriesList = document.querySelector<HTMLElement>('[data-entries]');
  const layout = document.querySelector<HTMLElement>('[data-list-layout]');
  if (entriesList) {
    const filterPills = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-filter-pills] [data-filter]')
    );
    const sortToggle = document.querySelector<HTMLButtonElement>('[data-sort-toggle]');

    const loadMoreBtn = document.querySelector<HTMLButtonElement>('[data-load-more]');

    createListController({
      container: entriesList,
      itemSelector: '[data-entry]',
      emptyState: document.querySelector<HTMLElement>('[data-empty]'),
      filter: {
        pills: filterPills,
        attr: 'data-type',
      },
      sort: sortToggle
        ? {
            toggle: sortToggle,
            attr: 'data-updated',
            arrow: sortToggle.querySelector<HTMLElement>('.sort-arrow'),
            ariaLabelFor: dir => `Sort: ${dir === 'asc' ? 'oldest first' : 'newest first'}`,
          }
        : undefined,
      tag: {
        attr: 'data-tags',
        activeWrap: document.querySelector<HTMLElement>('[data-active-tag]'),
        activeName: document.querySelector<HTMLElement>('[data-active-tag-name]'),
        clearButton: document.querySelector<HTMLButtonElement>('[data-tag-clear]'),
        clickRoot: layout ?? document,
        tagRoot: layout ?? entriesList,
      },
      loadMore: loadMoreBtn
        ? {
            button: loadMoreBtn,
            pageSize: 10,
            label: remaining => `load more · ${remaining}`,
          }
        : undefined,
    });
  }
</script>

---
import type { QuickLink } from '../../config';
import { computeLayout } from '../../lib/bento';

interface Props {
  links: QuickLink[];
}
const { links } = Astro.props;

// Curated lucide-style stroke icons (24px, currentColor). A `icon` name that
// isn't in this map falls through to rendering the raw string, so an emoji or
// short glyph from config works without an entry here.
const ICONS: Record<string, string> = {
  github:
    '<path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.4 9.4 0 0 1 12 6.83c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.48A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/>',
  book:
    '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/>',
  globe:
    '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"/>',
  link:
    '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  file:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M9 13h6"/><path d="M9 17h6"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  rocket:
    '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09Z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  lightbulb:
    '<path d="M15 14c.2-1 .7-2 1.5-2.5C18 10 19 8.5 19 7a7 7 0 1 0-14 0c0 1.5 1 3 2.5 4.5.8.5 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  rss: '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>',
  mail:
    '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  coffee:
    '<path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/><path d="M6 2v2"/>',
  'arrow-up-right': '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>',
};

// Literal class strings (no interpolation) so Tailwind's content scanner sees
// every col-span-N / sm:col-span-N / md:col-span-N variant and generates the
// CSS. Index = desktop column count (1-6). Tablet caps at 2, mobile at 1.
const SPAN_CLASSES = [
  'col-span-1 sm:col-span-1 md:col-span-1',
  'col-span-1 sm:col-span-2 md:col-span-2',
  'col-span-1 sm:col-span-2 md:col-span-3',
  'col-span-1 sm:col-span-2 md:col-span-4',
  'col-span-1 sm:col-span-2 md:col-span-5',
  'col-span-1 sm:col-span-2 md:col-span-6',
];

const layout = computeLayout(links);

function isExternal(url: string): boolean {
  return /^https?:\/\//i.test(url);
}
---

<section
  class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-6"
  data-quick-links
>
  {links.map((l, i) => {
    const ext = isExternal(l.url);
    const icon = l.icon ?? 'link';
    const svg = ICONS[icon];
    const cell = layout[i];
    return (
      <a
        href={l.url}
        class:list={[
          'group flex h-full flex-col gap-3 rounded-xl border border-border bg-card p-4 transition-colors hover:border-foreground/30 hover:bg-muted focus-visible:border-foreground/30 focus-visible:bg-muted focus-visible:outline-none',
          SPAN_CLASSES[cell.cols - 1],
        ]}
        {...ext ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
      >
        <div class="flex items-center gap-3">
          <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-muted text-faint transition-colors group-hover:text-foreground">
            {svg ? (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={svg}
              />
            ) : (
              <span class="text-base leading-none">{icon}</span>
            )}
          </span>
          <span class="flex items-center gap-1 font-serif text-base font-normal text-foreground group-hover:text-primary">
            {l.label}
            {ext && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-faint transition-colors group-hover:text-primary"
                aria-hidden="true"
              >
                <path d="M7 7h10v10" /><path d="M7 17 17 7" />
              </svg>
            )}
          </span>
        </div>
        {l.description && (
          <p class="m-0 font-serif text-sm leading-relaxed text-muted-foreground text-pretty">
            {l.description}
          </p>
        )}
      </a>
    );
  })}
</section>

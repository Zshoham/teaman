---
import { SITE_CONFIG } from '../config';
import { ThemeToggle } from './ThemeToggle';
import { loadDailyWeeks, weekHref } from '../lib/dailies';

const base = import.meta.env.BASE_URL;
const logoUrl = SITE_CONFIG.logo ? `${base}${SITE_CONFIG.logo}` : null;

// Link straight at the latest week. `/daily/` works too (it redirects), but
// the redirect renders a brief intermediate page in static builds — pointing
// at the resolved week URL keeps the click instant.
const dailyDir = `${base}daily/`;
const dailyWeeks = await loadDailyWeeks();
const dailyHref = dailyWeeks[0] ? weekHref(dailyWeeks[0]) : dailyDir;
const onDaily = Astro.url.pathname.startsWith(dailyDir);

const decisionsDir = `${base}decisions/`;
const onDecisions = Astro.url.pathname.startsWith(decisionsDir);
---

<header
  id="site-header"
  class="sticky top-0 z-30 grid min-w-0 grid-cols-[minmax(0,1fr)_auto] gap-4 border-b border-border bg-background pt-5 pb-4 md:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] md:gap-6 md:pt-7 md:pb-5"
>
  <a href={base} class="brand flex items-center gap-2.5 text-foreground no-underline">
    {logoUrl
      ? <span
          class="inline-block h-5 w-5 bg-current"
          style={`--brand-logo: url('${logoUrl}'); -webkit-mask: var(--brand-logo) center / contain no-repeat; mask: var(--brand-logo) center / contain no-repeat;`}
          aria-hidden="true"
        ></span>
      : <span class="inline-block h-2.5 w-2.5 rounded-sm bg-primary" aria-hidden="true"></span>
    }
    <span class="brand-name font-mono text-meta-lg font-medium tracking-wide">{SITE_CONFIG.brand}</span>
    <span class="brand-tagline ml-1 min-w-0 truncate font-mono text-meta text-faint">/ {SITE_CONFIG.tagline}</span>
  </a>

  <nav
    class="section-nav col-span-2 row-start-2 flex min-w-0 items-center justify-center gap-4 md:col-span-1 md:col-start-2 md:row-start-1"
    aria-label="Sections"
  >
    <a
      href={dailyHref}
      class:list={[
        'border-b py-0.5 font-mono text-meta-lg no-underline transition-colors',
        onDaily
          ? 'border-primary text-foreground'
          : 'border-transparent text-muted-foreground hover:text-foreground',
      ]}
      aria-current={onDaily ? 'page' : undefined}
    >daily</a>
    <a
      href={decisionsDir}
      class:list={[
        'border-b py-0.5 font-mono text-meta-lg no-underline transition-colors',
        onDecisions
          ? 'border-primary text-foreground'
          : 'border-transparent text-muted-foreground hover:text-foreground',
      ]}
      aria-current={onDecisions ? 'page' : undefined}
    >decisions</a>
  </nav>

  <div class="col-span-2 row-start-3 flex min-w-0 w-full items-center justify-between gap-3 md:col-span-1 md:col-start-3 md:row-start-1 md:w-auto md:justify-self-end md:gap-5">
    <pagefind-modal-trigger class="w-full max-w-[320px] md:w-auto">
      <button
        type="button"
        class="flex w-full cursor-pointer items-center gap-2.5 rounded-md border border-border bg-transparent py-1.5 pr-2 pl-3 font-[inherit] text-foreground transition-colors hover:border-foreground hover:bg-muted focus-visible:border-foreground focus-visible:bg-muted focus-visible:outline-none md:w-60"
        aria-label="Search the vault"
      >
        <span class="font-mono text-meta-lg leading-none text-faint" aria-hidden="true">⌕</span>
        <span class="flex-1 min-w-0 text-left text-meta-lg text-muted-foreground">search the vault</span>
        <span class="shrink-0 rounded-sm border border-border bg-background px-1.5 py-[3px] font-mono text-meta-sm leading-none text-faint" aria-hidden="true">/</span>
      </button>
    </pagefind-modal-trigger>

    <ThemeToggle client:load />
  </div>
</header>

<script>
  // Publish the sticky header's height as --header-h so in-page sticky
  // elements (filter bar, week strip, sidebars) can pin just below it
  // rather than sliding underneath. The header wraps to extra rows at
  // narrow widths, so measure it instead of hardcoding a breakpoint value.
  const header = document.getElementById('site-header');
  if (header) {
    const setHeaderH = () =>
      document.documentElement.style.setProperty('--header-h', `${header.offsetHeight}px`);
    setHeaderH();
    new ResizeObserver(setHeaderH).observe(header);
  }

  // '/' opens the pagefind modal — matches the kbd hint in the search box.
  window.addEventListener('keydown', (e) => {
    if (e.key !== '/' || e.metaKey || e.ctrlKey || e.altKey) return;
    const t = e.target;
    if (t instanceof HTMLElement && (t.matches('input, textarea, [contenteditable], [contenteditable=""]') || t.isContentEditable)) return;
    e.preventDefault();
    document.querySelector('pagefind-modal-trigger button')?.click();
  });
</script>

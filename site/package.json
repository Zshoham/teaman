{
  "name": "teaman",
  "version": "1.0.0",
  "description": "Static site generator for Obsidian vaults (Astro engine).",
  "type": "module",
  "bin": {
    "teaman": "./bin/teaman.mjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "resources",
    "astro.config.mjs",
    "components.json",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:all",
    "build:astro": "astro build",
    "preview": "astro preview",
    "build:slides": "node scripts/build-slides.mjs",
    "build:search": "node scripts/build-search.mjs",
    "build:all": "npm run build:astro && npm run build:slides && npm run build:search",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sync:confluence": "node scripts/sync-confluence.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "pagefind": "^1.5.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^2.1.2",
    "rehype-slug": "^6.0.0",
    "remark-wiki-link": "^2.0.1",
    "semver": "^7.8.1",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "vite": "8.0.13"
  }
}

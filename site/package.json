{
  "name": "teaman-site",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:all",
    "build:astro": "astro build",
    "preview": "astro preview",
    "build:slides": "node scripts/build-slides.mjs",
    "build:search": "node scripts/build-search.mjs",
    "build:all": "npm run build:astro && npm run build:slides && npm run build:search",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sync:confluence": "node scripts/sync-confluence.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@slidev/cli": "^52.15.1",
    "@slidev/theme-default": "^0.25.0",
    "astro": "^5.0.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^1.0.0",
    "rehype-slug": "^6.0.0",
    "remark-wiki-link": "^2.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.6"
  }

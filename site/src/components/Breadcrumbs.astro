---
export interface BreadcrumbSegment {
  label: string;
  /** Omit to render as the current (non-link) segment. */
  href?: string;
}

interface Props {
  segments: BreadcrumbSegment[];
}

const { segments } = Astro.props;
---

<p class="crumbs mb-7 flex flex-wrap items-baseline gap-2 font-mono text-[11px] text-faint">
  {segments.map((s, i) => (
    <>
      {i > 0 && <span>/</span>}
      {s.href
        ? <a href={s.href} class="text-mute no-underline hover:text-ink">{s.label}</a>
        : <span class="text-ink">{s.label}</span>
      }
    </>
  ))}
</p>

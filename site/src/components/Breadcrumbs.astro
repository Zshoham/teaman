---
export interface BreadcrumbSegment {
  label: string;
  /** Omit to render as the current (non-link) segment. */
  href?: string;
}

interface Props {
  segments: BreadcrumbSegment[];
}

const { segments } = Astro.props;
---

<p class="crumbs mono">
  {segments.map((s, i) => (
    <>
      {i > 0 && <span class="sep">/</span>}
      {s.href
        ? <a href={s.href}>{s.label}</a>
        : <span class="crumb-current">{s.label}</span>
      }
    </>
  ))}
</p>

<style>
  .crumbs {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 11px;
    color: var(--faint);
    margin: 0 0 28px;
    flex-wrap: wrap;
  }
  .crumbs a {
    color: var(--mute);
    text-decoration: none;
  }
  .crumbs a:hover { color: var(--ink); }
  .crumb-current { color: var(--ink); }
</style>

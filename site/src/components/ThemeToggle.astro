---
// Toggles `data-theme` on <html> and persists the choice in localStorage.
// The matching initial-load script lives in Layout.astro so it runs before
// any HTML paints, avoiding a flash of incorrect theme.
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  <svg class="theme-icon theme-icon-sun" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="8" cy="8" r="2.8" fill="currentColor" stroke="none"></circle>
    <path d="M8 1.5v1.6M8 12.9v1.6M14.5 8h-1.6M3.1 8H1.5M12.6 3.4l-1.1 1.1M4.5 11.5l-1.1 1.1M12.6 12.6l-1.1-1.1M4.5 4.5L3.4 3.4"></path>
  </svg>
  <svg class="theme-icon theme-icon-moon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M13 9.5A5 5 0 0 1 6.5 3 5 5 0 1 0 13 9.5z" fill="currentColor" stroke="none"></path>
  </svg>
</button>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('vault-theme', next); } catch {}
  });
</script>

<style>
  .theme-toggle {
    appearance: none;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0.5px solid var(--hairline);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    padding: 0;
    transition: border-color .15s, background .15s;
  }
  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    border-color: var(--ink);
    background: var(--surface);
    outline: none;
  }
  .theme-icon { display: block; }
  .theme-icon-moon { display: none; }
  :global(:root[data-theme='dark']) .theme-icon-sun { display: none; }
  :global(:root[data-theme='dark']) .theme-icon-moon { display: block; }
</style>

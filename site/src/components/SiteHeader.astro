---
import { SITE_CONFIG } from '../config';
import ThemeToggle from './ThemeToggle.astro';
import { loadDailyWeeks, weekHref } from '../lib/dailies';

const base = import.meta.env.BASE_URL;
const logoUrl = SITE_CONFIG.logo ? `${base}${SITE_CONFIG.logo}` : null;

// Link straight at the latest week. `/daily/` works too (it redirects), but
// the redirect renders a brief intermediate page in static builds — pointing
// at the resolved week URL keeps the click instant.
const dailyDir = `${base}daily/`;
const dailyWeeks = await loadDailyWeeks();
const dailyHref = dailyWeeks[0] ? weekHref(dailyWeeks[0]) : dailyDir;
const onDaily = Astro.url.pathname.startsWith(dailyDir);
---

<header class="vault-header">
  <a href={base} class="brand">
    {logoUrl
      ? <span class="brand-logo" style={`--brand-logo: url('${logoUrl}')`} aria-hidden="true"></span>
      : <span class="brand-mark" aria-hidden="true"></span>
    }
    <span class="brand-name mono">{SITE_CONFIG.brand}</span>
    <span class="brand-tagline mono">/ {SITE_CONFIG.tagline}</span>
  </a>

  <nav class="header-nav" aria-label="Sections">
    <a
      href={dailyHref}
      class:list={['nav-link mono', { 'nav-link-active': onDaily }]}
      aria-current={onDaily ? 'page' : undefined}
    >daily</a>
  </nav>

  <div class="header-tools">
    <pagefind-modal-trigger>
      <button type="button" class="search-trigger" aria-label="Search the vault">
        <span class="search-glyph mono" aria-hidden="true">⌕</span>
        <span class="search-placeholder">search the vault</span>
        <span class="search-kbd mono" aria-hidden="true">/</span>
      </button>
    </pagefind-modal-trigger>

    <ThemeToggle />
  </div>
</header>

<script>
  // '/' opens the pagefind modal — matches the kbd hint in the search box.
  window.addEventListener('keydown', (e) => {
    if (e.key !== '/' || e.metaKey || e.ctrlKey || e.altKey) return;
    const t = e.target as HTMLElement | null;
    if (t && (t.matches('input, textarea, [contenteditable], [contenteditable=""]') || t.isContentEditable)) return;
    e.preventDefault();
    document.querySelector<HTMLButtonElement>('pagefind-modal-trigger button')?.click();
  });
</script>

<style>
  .vault-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 28px 0 22px;
    border-bottom: 0.5px solid var(--hairline);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }
  .brand-mark {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--accent);
  }
  .brand-logo {
    display: inline-block;
    width: 20px;
    height: 20px;
    background-color: currentColor;
    -webkit-mask: var(--brand-logo) center / contain no-repeat;
            mask: var(--brand-logo) center / contain no-repeat;
  }
  .brand-name {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .brand-tagline {
    font-size: 11px;
    color: var(--faint);
    margin-left: 4px;
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-self: end;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-self: center;
  }
  .nav-link {
    font-size: 12px;
    color: var(--mute);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: color .12s, border-color .12s;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link-active,
  .nav-link-active:hover {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 240px;
    padding: 6px 8px 6px 12px;
    border: 0.5px solid var(--hairline);
    border-radius: 7px;
    background: transparent;
    cursor: pointer;
    color: var(--ink);
    font-family: inherit;
    transition: border-color .15s, background .15s;
  }
  .search-trigger:hover,
  .search-trigger:focus-visible {
    border-color: var(--ink);
    background: var(--surface);
    outline: none;
  }
  .search-glyph { color: var(--faint); font-size: 13px; line-height: 1; }
  .search-placeholder {
    flex: 1;
    min-width: 0;
    text-align: left;
    color: var(--faint);
    font-size: 13px;
  }
  .search-kbd {
    flex-shrink: 0;
    color: var(--faint);
    font-size: 10px;
    line-height: 1;
    padding: 3px 6px;
    border: 0.5px solid var(--hairline);
    border-radius: 4px;
    background: var(--bg);
  }

  @media (max-width: 880px) {
    .vault-header {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'brand nav'
        'tools tools';
      row-gap: 16px;
    }
    .brand { grid-area: brand; }
    .header-nav { grid-area: nav; justify-self: end; }
    .header-tools { grid-area: tools; width: 100%; justify-self: stretch; justify-content: space-between; }
    .search-trigger { width: 100%; max-width: 320px; }
  }
</style>

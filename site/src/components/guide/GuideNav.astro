---
import { chapterHref, type Guide } from '../../lib/guides';

interface Props {
  guide: Guide;
  currentSlug: string;
}

const { guide, currentSlug } = Astro.props;
const idx = guide.chapters.findIndex(c => c.slug === currentSlug);
const prev = idx > 0 ? guide.chapters[idx - 1] : null;
const next = idx >= 0 && idx < guide.chapters.length - 1 ? guide.chapters[idx + 1] : null;
---

<nav class="mt-14 grid grid-cols-1 gap-4 border-t border-hairline pt-6 font-mono md:grid-cols-2" aria-label="Chapter navigation">
  {prev ? (
    <a
      class="flex flex-col gap-1 rounded-md border border-hairline px-4 py-3.5 text-ink no-underline transition-colors hover:border-ink hover:bg-surface"
      href={chapterHref(guide, prev.slug)}
    >
      <span class="text-[10.5px] uppercase tracking-wider text-faint">← previous</span>
      <span class="font-serif text-[15px] text-balance text-ink">{prev.title}</span>
    </a>
  ) : <span></span>}
  {next ? (
    <a
      class="guide-nav-link next flex flex-col items-start gap-1 rounded-md border border-hairline px-4 py-3.5 text-ink no-underline transition-colors hover:border-ink hover:bg-surface md:items-end md:text-right"
      href={chapterHref(guide, next.slug)}
    >
      <span class="text-[10.5px] uppercase tracking-wider text-faint">next →</span>
      <span class="font-serif text-[15px] text-balance text-ink">{next.title}</span>
    </a>
  ) : <span></span>}
</nav>

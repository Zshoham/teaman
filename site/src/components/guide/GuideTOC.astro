---
import { chapterHref, type Guide } from '../../lib/guides';

interface Props {
  guide: Guide;
  currentSlug: string;
}

const { guide, currentSlug } = Astro.props;
const currentIdx = guide.chapters.findIndex(c => c.slug === currentSlug);
---

<aside class="guide-toc self-start md:sticky md:top-6 md:pr-2">
  <h2 class="m-0 mb-4 border-b border-hairline pb-2.5 font-mono text-[10.5px] font-normal uppercase tracking-[0.1em] text-faint">{guide.title}</h2>
  <ol class="m-0 flex list-none flex-col gap-0.5 p-0">
    {guide.chapters.map((ch, i) => {
      const current = i === currentIdx;
      return (
        <li class={current ? 'is-current' : ''}>
          <a
            href={chapterHref(guide, ch.slug)}
            class:list={[
              'flex items-baseline gap-2.5 border-b border-dashed border-hairline py-1.5 text-[13px] no-underline transition-colors',
              current ? 'text-ink' : 'text-mute hover:text-ink',
            ]}
          >
            <span class:list={[
              'shrink-0 font-mono text-[10.5px] tabular-nums',
              current ? 'text-accent' : 'text-faint',
            ]}>{String(i + 1).padStart(2, '0')}</span>
            <span class="font-serif text-balance">{ch.title}</span>
          </a>
        </li>
      );
    })}
  </ol>
</aside>

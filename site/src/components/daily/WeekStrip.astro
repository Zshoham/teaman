---
import type { DailyWeek } from '../../lib/dailies';
import { weekHref } from '../../lib/dailies';
import { fmtDayRange, fmtWeeksAgo } from '../../lib/format';
import DatePicker from './DatePicker.astro';

interface Props {
  weeks: DailyWeek[];
  currentId: string;
}

const { weeks, currentId } = Astro.props;
const currentIdx = weeks.findIndex(w => w.id === currentId);
const prev = currentIdx >= 0 && currentIdx < weeks.length - 1 ? weeks[currentIdx + 1] : null;
const next = currentIdx > 0 ? weeks[currentIdx - 1] : null;

// `weeks` is newest-first (consumed that way elsewhere). The strip renders
// oldest → newest left-to-right so the chevron directions match the visual
// motion: left = older = leftward; right = newer = rightward.
const chipWeeks = weeks.slice().reverse();

const navBtn =
  'inline-flex min-w-[38px] items-center justify-center rounded-md border border-hairline bg-transparent px-3 text-ink no-underline transition-colors hover:border-ink hover:bg-surface md:px-3.5';
const disabledBtn = 'pointer-events-none cursor-default text-faint';
---

<div class="sticky top-0 z-[8] border-b border-hairline bg-bg pt-3.5 pb-3" data-week-strip>
  <div class="flex items-stretch gap-2.5">
    {prev
      ? (
        <a class={navBtn} href={weekHref(prev)} title={`previous week — ${fmtDayRange(prev.start, prev.end)}`} aria-label="Previous week">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3L5 8l5 5"/></svg>
        </a>
      ) : (
        <span class={`${navBtn} ${disabledBtn}`} aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3L5 8l5 5"/></svg>
        </span>
      )
    }

    <div
      class="flex min-w-0 flex-1 items-stretch gap-2 overflow-hidden scroll-smooth [-webkit-mask-image:linear-gradient(to_right,transparent,black_24px,black_calc(100%-24px),transparent)] [mask-image:linear-gradient(to_right,transparent,black_24px,black_calc(100%-24px),transparent)]"
      data-strip-chips
    >
      {chipWeeks.map(w => {
        const active = w.id === currentId;
        const range = fmtDayRange(w.start, w.end);
        const chipCls = [
          'flex shrink-0 items-baseline gap-2 rounded-md border bg-transparent px-3.5 py-2 whitespace-nowrap text-ink no-underline transition-colors',
          active
            ? 'border-accent'
            : 'border-hairline hover:border-mute hover:bg-surface',
        ];
        return (
          <a
            class:list={chipCls}
            href={weekHref(w)}
            data-week={w.id}
            data-current={active ? 'true' : 'false'}
            aria-current={active ? 'page' : undefined}
          >
            <span class="tabular-nums font-mono text-[12px] text-inherit">{range}</span>
            <span class="tabular-nums font-mono text-[10px] text-faint">{fmtWeeksAgo(w.start)}</span>
          </a>
        );
      })}
    </div>

    {next
      ? (
        <a class={navBtn} href={weekHref(next)} title={`next week — ${fmtDayRange(next.start, next.end)}`} aria-label="Next week">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3l5 5-5 5"/></svg>
        </a>
      ) : (
        <span class={`${navBtn} ${disabledBtn}`} aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3l5 5-5 5"/></svg>
        </span>
      )
    }

    <DatePicker weeks={weeks} currentId={currentId} />
  </div>
</div>

<script>
  // Center the active chip whenever the strip first paints. Each week change
  // is a full page load, so this runs on every visit.
  const chips = document.querySelector<HTMLElement>('[data-strip-chips]');
  const active = chips?.querySelector<HTMLElement>('[data-current="true"]');
  if (chips && active) {
    const target = active.offsetLeft - chips.clientWidth / 2 + active.clientWidth / 2;
    chips.scrollTo({ left: Math.max(0, target), behavior: 'instant' as ScrollBehavior });
  }
</script>

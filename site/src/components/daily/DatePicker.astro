---
import type { DailyWeek } from '../../lib/dailies';
import {
  addDays,
  isoDate,
  sundayOf,
  weekHref,
  WEEKDAY_INITIALS,
} from '../../lib/dailies';

interface Props {
  weeks: DailyWeek[];
  currentId: string;
}

const { weeks, currentId } = Astro.props;

// Map: ISO Sunday date → week. Used to mark week-rows with notes.
const bySunday: Record<string, DailyWeek> = Object.fromEntries(weeks.map(w => [w.start, w]));

// Data bounds — restrict month nav to the months that actually contain weeks.
const sorted = weeks.slice().sort((a, b) => a.start.localeCompare(b.start));
const earliest = new Date(`${sorted[0]?.start ?? isoDate(new Date())}T00:00:00`);
const latest = new Date(`${sorted[sorted.length - 1]?.start ?? isoDate(new Date())}T00:00:00`);
const minMonth = `${earliest.getFullYear()}-${String(earliest.getMonth() + 1).padStart(2, '0')}`;
const maxMonth = `${latest.getFullYear()}-${String(latest.getMonth() + 1).padStart(2, '0')}`;

// Pre-render every month between earliest and latest (inclusive). The popover
// hides all but one at a time and the month-nav buttons swap which is shown.
interface MonthView {
  key: string; // 'YYYY-MM'
  year: number;
  month: number;
  label: string;
  rows: Array<{
    sundayIso: string;
    days: Array<{ day: number; inMonth: boolean }>;
    week: DailyWeek | null;
    active: boolean;
  }>;
}

function monthLabel(year: number, month: number): string {
  return new Date(year, month, 1).toLocaleString('en-US', { month: 'long' }).toLowerCase();
}

function buildMonth(year: number, month: number): MonthView {
  // First Sunday of the month's calendar view.
  const first = new Date(year, month, 1);
  const start = sundayOf(first);
  const rows: MonthView['rows'] = [];
  let cursor = start;
  for (let r = 0; r < 6; r++) {
    const sundayIso = isoDate(cursor);
    const days = [];
    for (let i = 0; i < 7; i++) {
      const d = addDays(cursor, i);
      days.push({ day: d.getDate(), inMonth: d.getMonth() === month });
    }
    const week = bySunday[sundayIso] ?? null;
    rows.push({
      sundayIso,
      days,
      week,
      active: !!week && week.id === currentId,
    });
    cursor = addDays(cursor, 7);
    if (cursor.getMonth() !== month && r >= 3) break;
  }
  return {
    key: `${year}-${String(month + 1).padStart(2, '0')}`,
    year,
    month,
    label: monthLabel(year, month),
    rows,
  };
}

const months: MonthView[] = [];
{
  let y = earliest.getFullYear();
  let m = earliest.getMonth();
  while (y < latest.getFullYear() || (y === latest.getFullYear() && m <= latest.getMonth())) {
    months.push(buildMonth(y, m));
    m += 1;
    if (m > 11) { m = 0; y += 1; }
  }
}

// Decide which month to show first — the month of the current week.
const currentWeek = weeks.find(w => w.id === currentId) ?? weeks[0];
const currentDate = new Date(`${currentWeek.start}T00:00:00`);
const initialKey = `${currentDate.getFullYear()}-${String(currentDate.getMonth() + 1).padStart(2, '0')}`;

const rowGrid = 'grid grid-cols-[24px_repeat(7,1fr)_16px] items-center gap-1 text-center';
---

<div class="relative inline-flex" data-archive>
  <button
    type="button"
    class="inline-flex h-full cursor-pointer items-center gap-1.5 rounded-md border border-hairline bg-transparent px-3 font-[inherit] text-[12px] text-ink transition-colors hover:border-ink hover:bg-surface aria-expanded:border-ink aria-expanded:bg-surface"
    data-archive-toggle
    aria-haspopup="dialog"
    aria-expanded="false"
    title="jump to a week"
  >
    <span class="font-mono">archive</span>
    <svg
      class="text-faint"
      width="10" height="10" viewBox="0 0 16 16"
      fill="none" stroke="currentColor" stroke-width="1.25"
      stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M4 6l4 4 4-4"/>
    </svg>
  </button>

  <div
    class="absolute top-[calc(100%+8px)] right-0 z-[12] w-[308px] rounded-[10px] border border-hairline bg-surface p-3.5 shadow-[0_12px_32px_rgba(0,0,0,0.12)]"
    role="dialog"
    aria-label="Pick a week"
    data-archive-popover
    hidden
  >
    <div class="mb-3 flex items-center justify-between gap-2">
      <button
        type="button"
        class="inline-flex h-[26px] w-[26px] cursor-pointer items-center justify-center rounded border border-hairline bg-transparent text-ink transition-colors hover:border-ink hover:bg-bg disabled:cursor-default disabled:border-hairline disabled:bg-transparent disabled:text-faint"
        data-archive-prev
        aria-label="Previous month"
      >
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3L5 8l5 5"/></svg>
      </button>
      <div
        class="flex-1 text-center font-mono text-[12px] tabular-nums uppercase tracking-[0.08em] text-ink"
        data-archive-label
      >
        {months.map(m => (
          <span
            class="month-label"
            data-month={m.key}
            data-active={m.key === initialKey ? 'true' : 'false'}
            hidden={m.key !== initialKey}
          >
            {m.label}
            <span class="ml-2 text-faint">{m.year}</span>
          </span>
        ))}
      </div>
      <button
        type="button"
        class="inline-flex h-[26px] w-[26px] cursor-pointer items-center justify-center rounded border border-hairline bg-transparent text-ink transition-colors hover:border-ink hover:bg-bg disabled:cursor-default disabled:border-hairline disabled:bg-transparent disabled:text-faint"
        data-archive-next
        aria-label="Next month"
      >
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3l5 5-5 5"/></svg>
      </button>
    </div>

    <div class={`${rowGrid} mb-1.5`}>
      <span />
      {WEEKDAY_INITIALS.map((d, i) => (
        <span class="font-mono text-[10px] tracking-[0.08em] text-faint" data-i={i}>{d}</span>
      ))}
      <span />
    </div>

    <div>
      {months.map(month => (
        <div
          class="month flex flex-col gap-0.5"
          data-month={month.key}
          data-min={month.key === minMonth ? 'true' : 'false'}
          data-max={month.key === maxMonth ? 'true' : 'false'}
          hidden={month.key !== initialKey}
        >
          {month.rows.map(row => {
            const monthIso = String(month.month + 1).padStart(2, '0');
            const hasNotes = !!row.week;
            const baseCls = [
              rowGrid,
              'rounded py-1 outline outline-transparent transition-colors',
              row.active ? 'bg-bg outline-ink' : '',
              hasNotes ? 'hover:bg-bg' : 'cursor-default',
            ];
            return hasNotes ? (
              <a
                class:list={baseCls}
                href={weekHref(row.week!)}
                title={`jump to week of ${row.sundayIso}`}
              >
                <span class="tabular-nums font-mono text-[9px] text-faint">{monthIso}</span>
                {row.days.map(d => (
                  <span class:list={[
                    'tabular-nums font-mono py-1 text-[12px]',
                    d.inMonth ? 'text-ink' : 'text-mute opacity-55',
                  ]}>{d.day}</span>
                ))}
                <span class="row-dot row-dot-on inline-block h-[5px] w-[5px] justify-self-center rounded-full bg-accent/90" aria-hidden="true" />
              </a>
            ) : (
              <span class:list={baseCls}>
                <span class="tabular-nums font-mono text-[9px] text-faint">{monthIso}</span>
                {row.days.map(d => (
                  <span class="tabular-nums font-mono py-1 text-[12px] text-faint opacity-55">{d.day}</span>
                ))}
                <span class="row-dot inline-block h-[5px] w-[5px] justify-self-center rounded-full bg-transparent" aria-hidden="true" />
              </span>
            );
          })}
        </div>
      ))}
    </div>

    <div class="mt-3 flex items-center justify-between border-t border-hairline pt-2.5 font-mono text-[10px] tracking-[0.08em] text-faint">
      <span class="uppercase">pick a week</span>
      <span class="inline-flex items-center">
        <span class="row-dot-on mr-1.5 inline-block h-[5px] w-[5px] rounded-full bg-accent/90 align-middle" aria-hidden="true" />
        has notes
      </span>
    </div>
  </div>
</div>

<script>
  import { initArchive } from '../../scripts/daily-archive';
  initArchive();
</script>

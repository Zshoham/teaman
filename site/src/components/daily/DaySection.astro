---
import { render } from 'astro:content';
import type { DailyEntry } from '../../lib/dailies';
import { WEEKDAY_LONG, dayAnchor } from '../../lib/dailies';
import { fmtLongDay } from '../../lib/format';

interface Props {
  day: DailyEntry;
  /** First day in the week skips the ornamental divider and extra top padding. */
  isFirst?: boolean;
}

const { day, isFirst = false } = Astro.props;
const weekdayLong = WEEKDAY_LONG[day.weekday];
const longDate = fmtLongDay(day.date);
const { Content } = await render(day.entry);
---

<section
  class:list={[
    'scroll-mt-24 pt-14 md:pt-[72px]',
    { 'pt-6 md:pt-8': isFirst },
  ]}
  id={dayAnchor(day.date)}
  data-day={day.date}
>
  {!isFirst && (
    <div class="mb-10 text-center font-mono text-sm tracking-[0.6em] text-faint md:mb-14" aria-hidden="true">· · ·</div>
  )}

  <header class="mb-9 text-center">
    <h2 class="m-0 font-serif text-3xl leading-[1.05] font-normal tracking-tight text-foreground md:text-[44px]">{weekdayLong}</h2>
    <span class="mt-2.5 block font-mono text-[12px] uppercase tracking-[0.16em] text-faint">{longDate}</span>
  </header>

  <div class="prose">
    <Content />
  </div>

  {day.tags.length > 0 && (
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      {day.tags.map(tag => (
        <span class="font-mono text-[11px] tracking-wide text-faint">#{tag}</span>
      ))}
    </div>
  )}
</section>

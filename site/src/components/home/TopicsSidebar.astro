---
interface Topic {
  tag: string;
  count: number;
}

interface Props {
  topics: Topic[];
  /** How many topics to show before the "show more" toggle. */
  initialShown?: number;
}

const { topics, initialShown = 8 } = Astro.props;
const overflow = Math.max(0, topics.length - initialShown);
---

<aside class="flex flex-col gap-9 self-start md:sticky md:top-20">
  <section>
    <h2 class="m-0 mb-3 border-b border-hairline pb-2 font-mono text-[10.5px] font-normal uppercase tracking-[0.1em] text-faint">topics</h2>
    <div class="flex flex-col gap-0.5" data-topics>
      {topics.map((t, i) => (
        <button
          type="button"
          class="topic flex cursor-pointer items-baseline justify-between border-0 border-b border-dashed border-hairline bg-transparent py-1 text-left font-mono text-[12px] text-mute transition-colors hover:text-ink [&.is-active]:text-ink"
          data-tag={t.tag}
          data-topic-index={i}
          hidden={i >= initialShown}
        >
          <span><span class="text-faint [.topic.is-active_&]:text-accent">#</span>{t.tag}</span>
          <span class="tabular-nums text-faint">{String(t.count).padStart(2, '0')}</span>
        </button>
      ))}
    </div>
    {overflow > 0 && (
      <button
        type="button"
        class="mt-2.5 inline-flex cursor-pointer items-baseline gap-1.5 border-0 bg-transparent py-1 font-mono text-[11px] text-accent"
        data-topics-toggle
        data-initial-shown={initialShown}
        aria-expanded="false"
      >
        <span data-topics-more-label>show {overflow} more</span>
        <span class="text-faint transition-transform aria-expanded:rotate-180" aria-hidden="true">↓</span>
      </button>
    )}
  </section>
</aside>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-topics-toggle]');
  if (toggle) {
    const initialShown = Number(toggle.dataset.initialShown ?? '8');
    const label = document.querySelector<HTMLElement>('[data-topics-more-label]');
    const overflowTopics = Array.from(
      document.querySelectorAll<HTMLElement>('[data-topic-index]')
    ).filter(el => Number(el.dataset.topicIndex) >= initialShown);
    const overflowCount = overflowTopics.length;

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      const next = !expanded;
      toggle.setAttribute('aria-expanded', String(next));
      overflowTopics.forEach(el => { el.hidden = !next; });
      if (label) {
        label.textContent = next ? 'show fewer' : `show ${overflowCount} more`;
      }
    });
  }
</script>

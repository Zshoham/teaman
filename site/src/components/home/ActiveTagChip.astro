---
// Rendered once; visibility and label are toggled by list-controller.
---

<div
  class="mb-2 flex items-baseline gap-2.5 rounded-md border border-hairline bg-surface px-3 py-2 font-mono"
  data-active-tag
  hidden
>
  <span class="text-[11px] text-faint">filtered by</span>
  <span class="text-[12px] text-accent" data-active-tag-name></span>
  <button
    type="button"
    class="ml-auto cursor-pointer border-0 bg-transparent text-[11px] text-mute"
    data-tag-clear
  >clear ×</button>
</div>

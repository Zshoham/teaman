---
import { TYPE_LABEL, type Entry } from '../../lib/entries';
import { fmtDate } from '../../lib/format';

interface Props {
  entry: Entry;
}

const { entry: e } = Astro.props;
---

<article
  class="entry py-7 [&:not([hidden])~&:not([hidden])]:border-t [&:not([hidden])~&:not([hidden])]:border-hairline"
  data-entry
  data-type={e.type}
  data-tags={e.tags.join(' ')}
  data-updated={e.updated}
  data-created={e.created}
  data-title={e.title.toLowerCase()}
>
  <div class="mb-2 flex items-baseline gap-3 font-mono text-[11px]">
    <span class="tabular-nums text-faint">{fmtDate(e.updated)}</span>
    <span class="text-accent">{TYPE_LABEL[e.type]}</span>
    <span class="ml-auto tabular-nums whitespace-nowrap text-faint">{e.meta}</span>
  </div>
  <h3 class="entry-title m-0 font-serif text-2xl leading-tight font-normal tracking-tight text-balance text-ink md:text-[28px]">
    <a href={e.href} class="text-inherit no-underline hover:text-accent">{e.title}</a>
  </h3>
  {e.excerpt && (
    <p class="mt-3 max-w-[700px] font-serif text-[15px] leading-relaxed text-mute text-pretty md:text-base">
      {e.excerpt}
    </p>
  )}
  {e.tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {e.tags.map(tag => (
        <button
          type="button"
          class="cursor-pointer border-0 bg-transparent p-0 font-mono text-[11px] tracking-wide text-faint hover:text-accent"
          data-tag={tag}
        >#{tag}</button>
      ))}
    </div>
  )}
</article>

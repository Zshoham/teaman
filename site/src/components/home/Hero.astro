---
import { relTime } from '../../lib/format';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  statRows: Array<[string, number]>;
  lastUpdated: string;
}

const { eyebrow, title, description, statRows, lastUpdated } = Astro.props;
---

<section class="grid items-end gap-8 border-b border-hairline py-9 md:grid-cols-[minmax(0,1fr)_280px] md:gap-16 md:pt-9 md:pb-11">
  <div>
    <p class="m-0 font-mono text-[11px] uppercase tracking-[0.08em] text-faint">{eyebrow}</p>
    <h1
      class="mt-3.5 font-serif text-4xl leading-[1.05] font-normal tracking-tight text-balance text-ink md:text-[56px] [&>em]:italic [&>em]:text-mute"
      set:html={title}
    ></h1>
    <p
      class="mt-5 max-w-[620px] font-serif text-[17px] leading-relaxed text-mute text-pretty"
      set:html={description}
    ></p>
  </div>
  <aside class="flex flex-col gap-1.5">
    {statRows.map(([label, n]) => (
      <div class="stat-row flex items-baseline justify-between gap-3 border-t border-hairline py-1.5 font-mono">
        <span class="text-[11px] text-mute">{label}</span>
        <span class="tabular-nums text-[13px] text-ink">{String(n).padStart(3, '0')}</span>
      </div>
    ))}
    <div class="flex items-baseline justify-between gap-3 pt-2.5 font-mono">
      <span class="text-[11px] text-faint">last edit</span>
      <span class="tabular-nums text-[11px] text-mute">{relTime(lastUpdated)}</span>
    </div>
  </aside>
</section>

---
interface FilterTab {
  id: string;
  label: string;
  count: number;
}

interface Props {
  filterTabs: FilterTab[];
  defaultFilter?: string;
}

const { filterTabs, defaultFilter = 'all' } = Astro.props;
---

<div class="sticky top-0 z-[5] -mx-px mb-1 flex flex-wrap items-center justify-between gap-4 border-b border-hairline bg-bg py-3.5">
  <div class="flex flex-wrap gap-1.5" data-filter-pills>
    {filterTabs.map(t => (
      <button
        type="button"
        class="inline-flex cursor-pointer items-baseline gap-2 rounded-full border border-hairline bg-transparent px-3 py-1 text-[12px] text-mute transition-colors hover:border-mute aria-pressed:border-ink aria-pressed:bg-ink aria-pressed:text-bg"
        data-filter={t.id}
        aria-pressed={t.id === defaultFilter ? 'true' : 'false'}
      >
        <span>{t.label}</span>
        <span class="font-mono text-[10px] opacity-60">{t.count}</span>
      </button>
    ))}
  </div>
  <button
    type="button"
    class="inline-flex cursor-pointer items-baseline gap-1 border-0 border-b border-accent bg-transparent py-0.5 font-mono text-[11px] text-ink hover:text-accent"
    data-sort-toggle
    aria-label="Sort: newest first"
  >
    date <span class="sort-arrow" aria-hidden="true">↓</span>
  </button>
</div>

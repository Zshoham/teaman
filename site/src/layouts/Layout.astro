---
import '../styles/global.css';
import { SITE_CONFIG } from '../config';
import SiteHeader from '../components/SiteHeader.astro';
import { version as pkgVersion } from '../../package.json';

// Engine version, stamped into <meta name="generator"> so a built site records
// which `teaman` produced it. The CLI passes TEAMAN_VERSION; otherwise the
// engine's own package.json version (inlined at build) is used.
const engineVersion = process.env.TEAMAN_VERSION ?? pkgVersion;

interface Props {
  /**
   * Page-specific title. The document `<title>` becomes `${title} — ${brand}`.
   * Omit on the home page to use the default `${brand} — ${tagline}`.
   */
  title?: string;
  /**
   * Optional override for the bottom-left footer text. Home page passes its
   * entry count + last-edit summary here.
   */
  footerLeft?: string;
}

const { title, footerLeft } = Astro.props;
const base = import.meta.env.BASE_URL;
const docTitle = title
  ? `${title} — ${SITE_CONFIG.brand}`
  : `${SITE_CONFIG.brand} — ${SITE_CONFIG.tagline}`;

// Per-vault theme overrides → a `:root` rule layered over global.css defaults.
const themeCss = SITE_CONFIG.theme
  ? `:root{${Object.entries(SITE_CONFIG.theme)
      .map(([token, value]) => `${token.startsWith('--') ? token : `--${token}`}:${value};`)
      .join('')}}`
  : '';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={`teaman ${engineVersion}`} />
  <title>{docTitle}</title>

  {themeCss && <style set:html={themeCss}></style>}

  <script is:inline>
    // Runs before paint to avoid a flash of incorrect theme.
    (() => {
      try {
        const stored = localStorage.getItem('vault-theme');
        if (stored === 'dark' || stored === 'light') {
          document.documentElement.dataset.theme = stored;
        }
      } catch {}
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
    rel="stylesheet"
  />

  <link rel="stylesheet" href={`${base}pagefind/pagefind-component-ui.css`} />
  <script type="module" is:inline src={`${base}pagefind/pagefind-component-ui.js`}></script>
</head>
<body>
  <div class="mx-auto max-w-[1180px] px-6 md:px-10">
    <SiteHeader />

    <pagefind-modal></pagefind-modal>

    <main class="pt-4">
      <slot />
    </main>

    <footer class="mt-16 flex flex-wrap items-baseline justify-between gap-4 border-t border-border px-0 pt-8 pb-12 font-mono text-[11px] text-faint">
      <span>{footerLeft ?? `${SITE_CONFIG.brand}`}</span>
      {SITE_CONFIG.footerNote && <span set:html={SITE_CONFIG.footerNote}></span>}
    </footer>
  </div>

  <script>
    // Renders any ```mermaid blocks on the page; no-ops (and skips loading
    // mermaid) when the page has none.
    import { initMermaid } from '../scripts/mermaid';
    initMermaid();
  </script>

  <script>
    // Renders any ```plantuml blocks on the page; no-ops (and skips loading the
    // multi-megabyte PlantUML engine) when the page has none.
    import { initPlantuml } from '../scripts/plantuml';
    initPlantuml();
  </script>
</body>
</html>

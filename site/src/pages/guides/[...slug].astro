---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GuideTOC from '../../components/guide/GuideTOC.astro';
import GuideNav from '../../components/guide/GuideNav.astro';
import { listGuides, getGuide } from '../../lib/guides';
import { readingTimeMeta, wordCount, wordMeta } from '../../lib/text';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const guides = await listGuides();
  const paths: Array<{
    params: { slug: string };
    props: { guideSlug: string; chapterSlug: string };
  }> = [];
  for (const g of guides) {
    if (g.chapters.length === 0) continue;
    const [first, ...rest] = g.chapters;
    paths.push({
      params: { slug: g.slug },
      props: { guideSlug: g.slug, chapterSlug: first.slug },
    });
    for (const ch of rest) {
      paths.push({
        params: { slug: `${g.slug}/${ch.slug}` },
        props: { guideSlug: g.slug, chapterSlug: ch.slug },
      });
    }
  }
  return paths;
}

const { guideSlug, chapterSlug } = Astro.props;
const guide = await getGuide(guideSlug);
if (!guide) throw new Error(`Guide not found: ${guideSlug}`);

const entries = await getCollection('guides');
const entry = entries.find(e => e.id === `${guideSlug}/${chapterSlug}`);
if (!entry) throw new Error(`Chapter not found: ${guideSlug}/${chapterSlug}`);

const { Content } = await render(entry);

const base = import.meta.env.BASE_URL;
const idx = guide.chapters.findIndex(c => c.slug === chapterSlug);
const currentTitle = guide.chapters[idx]?.title ?? entry.data.title ?? chapterSlug;
const docTitle = `${currentTitle} — ${guide.title}`;
const words = wordCount(entry.body ?? '');
---

<Layout title={docTitle}>
  <article class="guide">
    <Breadcrumbs segments={[
      { label: 'index', href: base },
      { label: guide.title, href: `${base}guides/${guide.slug}/` },
      ...(idx > 0 ? [{ label: currentTitle }] : []),
    ]} />

    <div class="guide-layout">
      <GuideTOC guide={guide} currentSlug={chapterSlug} />

      <div class="guide-body">
        <header class="guide-head">
          <p class="guide-eyebrow mono">guide · chapter {idx + 1} of {guide.chapters.length}</p>
          <h1 class="guide-title">{currentTitle}</h1>
          <p class="guide-meta mono">{wordMeta(words)} · {readingTimeMeta(words)}</p>
        </header>

        <div class="prose">
          <Content />
        </div>

        <GuideNav guide={guide} currentSlug={chapterSlug} />
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .vault .guide {
    padding: 24px 0 8px;
  }

  .vault .guide-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }

  .vault .guide-body {
    max-width: 720px;
    min-width: 0;
  }

  .vault .guide-head {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .vault .guide-eyebrow {
    margin: 0;
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .vault .guide-title {
    font-family: var(--display-font);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 12px 0 0;
    text-wrap: balance;
  }
  .vault .guide-meta {
    margin: 16px 0 0;
    font-size: 11px;
    color: var(--faint);
  }

  @media (max-width: 880px) {
    .vault .guide-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }
    .vault .guide-title { font-size: 32px; }
  }
</style>

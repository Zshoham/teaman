---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { listGuides, getGuide, type GuideChapter } from '../../lib/guides';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const guides = listGuides();
  const paths: Array<{
    params: { slug: string };
    props: { guideSlug: string; chapterSlug: string };
  }> = [];
  for (const g of guides) {
    if (g.chapters.length === 0) continue;
    const [first, ...rest] = g.chapters;
    paths.push({
      params: { slug: g.slug },
      props: { guideSlug: g.slug, chapterSlug: first.slug },
    });
    for (const ch of rest) {
      paths.push({
        params: { slug: `${g.slug}/${ch.slug}` },
        props: { guideSlug: g.slug, chapterSlug: ch.slug },
      });
    }
  }
  return paths;
}

const { guideSlug, chapterSlug } = Astro.props;
const guide = getGuide(guideSlug);
if (!guide) throw new Error(`Guide not found: ${guideSlug}`);

const entries = await getCollection('guides');
const entry = entries.find(e => e.id === `${guideSlug}/${chapterSlug}`);
if (!entry) throw new Error(`Chapter not found: ${guideSlug}/${chapterSlug}`);

const { Content } = await render(entry);

const base = import.meta.env.BASE_URL;
const idx = guide.chapters.findIndex(c => c.slug === chapterSlug);
const prev = idx > 0 ? guide.chapters[idx - 1] : null;
const next = idx >= 0 && idx < guide.chapters.length - 1 ? guide.chapters[idx + 1] : null;

const chapterHref = (ch: GuideChapter) => {
  const isFirst = guide.chapters[0]?.slug === ch.slug;
  return isFirst ? `${base}guides/${guide.slug}/` : `${base}guides/${guide.slug}/${ch.slug}/`;
};

const currentTitle = guide.chapters[idx]?.title ?? entry.data.title ?? chapterSlug;
const docTitle = `${currentTitle} — ${guide.title}`;
---

<Layout title={docTitle}>
  <article class="guide">
    <p class="crumbs mono">
      <a href={base}>index</a>
      <span class="sep">/</span>
      <a href={`${base}guides/${guide.slug}/`}>{guide.title}</a>
      {idx > 0 && (
        <>
          <span class="sep">/</span>
          <span class="crumb-current">{currentTitle}</span>
        </>
      )}
    </p>

    <div class="guide-layout">
      <aside class="guide-toc">
        <h2 class="toc-title mono">{guide.title}</h2>
        <ol class="toc-list">
          {guide.chapters.map((ch, i) => (
            <li class={`toc-item ${i === idx ? 'is-current' : ''}`}>
              <a href={chapterHref(ch)}>
                <span class="toc-num mono">{String(i + 1).padStart(2, '0')}</span>
                <span class="toc-label">{ch.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </aside>

      <div class="guide-body">
        <header class="guide-head">
          <p class="guide-eyebrow mono">guide · chapter {idx + 1} of {guide.chapters.length}</p>
          <h1 class="guide-title">{currentTitle}</h1>
        </header>

        <div class="prose">
          <Content />
        </div>

        <nav class="guide-nav mono" aria-label="Chapter navigation">
          {prev ? (
            <a class="guide-nav-link prev" href={chapterHref(prev)}>
              <span class="guide-nav-dir">← previous</span>
              <span class="guide-nav-label">{prev.title}</span>
            </a>
          ) : <span></span>}
          {next ? (
            <a class="guide-nav-link next" href={chapterHref(next)}>
              <span class="guide-nav-dir">next →</span>
              <span class="guide-nav-label">{next.title}</span>
            </a>
          ) : <span></span>}
        </nav>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .vault .guide {
    padding: 24px 0 8px;
  }

  .vault .guide .crumbs {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 11px;
    color: var(--faint);
    margin: 0 0 28px;
    flex-wrap: wrap;
  }
  .vault .guide .crumbs a {
    color: var(--mute);
    text-decoration: none;
  }
  .vault .guide .crumbs a:hover { color: var(--ink); }
  .vault .guide .crumbs .crumb-current { color: var(--ink); }

  .vault .guide-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }

  /* Sidebar TOC ────────────────────────────────────────────────────────── */
  .vault .guide-toc {
    position: sticky;
    top: 24px;
    align-self: start;
    padding-right: 8px;
  }
  .vault .toc-title {
    margin: 0 0 16px;
    padding-bottom: 10px;
    font-family: var(--mono-font);
    font-size: 10.5px;
    font-weight: 400;
    color: var(--faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 0.5px solid var(--hairline);
  }
  .vault .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .vault .toc-item a {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 6px 0;
    font-size: 13px;
    color: var(--mute);
    text-decoration: none;
    border-bottom: 0.5px dashed var(--hairline);
    transition: color .12s;
  }
  .vault .toc-item a:hover { color: var(--ink); }
  .vault .toc-item.is-current a { color: var(--ink); }
  .vault .toc-num {
    font-size: 10.5px;
    color: var(--faint);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .vault .toc-item.is-current .toc-num { color: var(--accent); }
  .vault .toc-label {
    font-family: var(--display-font);
    text-wrap: balance;
  }

  /* Guide body ─────────────────────────────────────────────────────────── */
  .vault .guide-body {
    max-width: 720px;
    min-width: 0;
  }

  .vault .guide-head {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .vault .guide-eyebrow {
    margin: 0;
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .vault .guide-title {
    font-family: var(--display-font);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 12px 0 0;
    text-wrap: balance;
  }

  /* Prev/next ──────────────────────────────────────────────────────────── */
  .vault .guide-nav {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 0.5px solid var(--hairline);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .vault .guide-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 0.5px solid var(--hairline);
    border-radius: 7px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color .15s, background .15s;
  }
  .vault .guide-nav-link:hover {
    border-color: var(--ink);
    background: var(--surface);
  }
  .vault .guide-nav-link.next {
    text-align: right;
    align-items: flex-end;
  }
  .vault .guide-nav-dir {
    font-size: 10.5px;
    color: var(--faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .vault .guide-nav-label {
    font-family: var(--display-font);
    font-size: 15px;
    color: var(--ink);
    text-wrap: balance;
  }

  @media (max-width: 880px) {
    .vault .guide-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }
    .vault .guide-toc {
      position: static;
      padding-right: 0;
    }
    .vault .guide-title { font-size: 32px; }
    .vault .guide-nav { grid-template-columns: 1fr; }
    .vault .guide-nav-link.next { text-align: left; align-items: flex-start; }
  }
</style>

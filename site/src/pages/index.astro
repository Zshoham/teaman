---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';
import { loadAllEntries } from '../lib/entries';
import { fmtDate } from '../lib/format';
import Hero from '../components/home/Hero.astro';
import FilterBar from '../components/home/FilterBar.astro';
import ActiveTagChip from '../components/home/ActiveTagChip.astro';
import EntryCard from '../components/home/EntryCard.astro';
import TopicsSidebar from '../components/home/TopicsSidebar.astro';

const entries = await loadAllEntries();

const counts: Record<string, number> = entries.reduce((acc, e) => {
  acc[e.type] = (acc[e.type] ?? 0) + 1;
  return acc;
}, {} as Record<string, number>);

const tagCounts = new Map<string, number>();
entries.forEach(e => e.tags.forEach(t => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)));
const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

const lastUpdated = entries[0]?.updated ?? new Date().toISOString().slice(0, 10);

const filterTabs = [
  { id: 'all', label: 'all', count: entries.length },
  { id: 'note', label: 'notes', count: counts.note ?? 0 },
  { id: 'guide', label: 'guides', count: counts.guide ?? 0 },
  { id: 'slides', label: 'slides', count: counts.slides ?? 0 },
].filter(t => t.id === 'all' || t.count > 0);

const statRows: Array<[string, number]> = [
  ['notes', counts.note ?? 0],
  ['guides', counts.guide ?? 0],
  ['slides', counts.slides ?? 0],
  ['tags', tagCounts.size],
].filter(([, n]) => n > 0) as Array<[string, number]>;

const footerLeft = `${entries.length} ${entries.length === 1 ? 'entry' : 'entries'} · last edit ${fmtDate(lastUpdated)}`;
---

<Layout footerLeft={footerLeft}>
  <Hero
    eyebrow={SITE_CONFIG.hero.eyebrow}
    title={SITE_CONFIG.hero.title}
    description={SITE_CONFIG.hero.description}
    statRows={statRows}
    lastUpdated={lastUpdated}
  />

  <div class="layout" data-has-sidebar={topics.length > 0 ? 'true' : 'false'}>
    <div class="content">
      <FilterBar filterTabs={filterTabs} />
      <ActiveTagChip />

      <div class="entries" data-entries>
        {entries.map(e => <EntryCard entry={e} />)}
      </div>
      <div class="empty-state mono" data-empty hidden>nothing matches.</div>
    </div>

    {topics.length > 0 && <TopicsSidebar topics={topics} />}
  </div>
</Layout>

<script>
  import { createListController } from '../scripts/list-controller';

  const entriesList = document.querySelector<HTMLElement>('[data-entries]');
  if (entriesList) {
    const filterPills = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-filter-pills] [data-filter]')
    );
    const sortToggle = document.querySelector<HTMLButtonElement>('[data-sort-toggle]');

    createListController({
      container: entriesList,
      itemSelector: '[data-entry]',
      emptyState: document.querySelector<HTMLElement>('[data-empty]'),
      filter: {
        pills: filterPills,
        attr: 'data-type',
      },
      sort: sortToggle
        ? {
            toggle: sortToggle,
            attr: 'data-updated',
            arrow: sortToggle.querySelector<HTMLElement>('.sort-arrow'),
            ariaLabelFor: dir => `Sort: ${dir === 'asc' ? 'oldest first' : 'newest first'}`,
          }
        : undefined,
      tag: {
        attr: 'data-tags',
        activeWrap: document.querySelector<HTMLElement>('[data-active-tag]'),
        activeName: document.querySelector<HTMLElement>('[data-active-tag-name]'),
        clearButton: document.querySelector<HTMLButtonElement>('[data-tag-clear]'),
      },
    });
  }
</script>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 240px;
    gap: 64px;
    padding-top: 16px;
  }
  .layout[data-has-sidebar="false"] {
    grid-template-columns: minmax(0, 1fr);
  }

  .entries {
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    padding: 40px 0;
    text-align: center;
    color: var(--faint);
    font-size: 14px;
  }
  .empty-state[hidden] { display: none; }

  @media (max-width: 880px) {
    .layout { grid-template-columns: minmax(0, 1fr); gap: 40px; }
  }
</style>

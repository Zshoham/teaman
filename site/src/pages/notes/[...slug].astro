---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', n => !n.data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) => {
  const m = d.toLocaleString('en-US', { month: 'short' }).toLowerCase();
  return `${String(d.getDate()).padStart(2, '0')} ${m} ${d.getFullYear()}`;
};
---

<Layout title={note.data.title ?? note.id}>
  <article class="note">
    <p class="crumbs mono">
      <a href={base}>index</a>
      <span class="sep">/</span>
      <span class="crumb-current">{note.id}</span>
    </p>

    <header class="note-head">
      <h1 class="note-title">{note.data.title ?? note.id}</h1>
      <div class="note-meta mono">
        {note.data.date && <time datetime={note.data.date.toISOString()}>{fmtDate(note.data.date)}</time>}
        {note.data.tags && note.data.tags.length > 0 && (
          <>
            <span class="dot">·</span>
            <span class="tags">
              {note.data.tags.map(tag => <span class="tag">#{tag}</span>)}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  .vault .note {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px 0 8px;
  }

  .vault .crumbs {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 11px;
    color: var(--faint);
    margin: 0 0 28px;
  }
  .vault .crumbs a {
    color: var(--mute);
    text-decoration: none;
  }
  .vault .crumbs a:hover { color: var(--ink); }
  .vault .crumb-current { color: var(--ink); }

  .vault .note-head {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .vault .note-title {
    font-family: var(--display-font);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .vault .note-meta {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 11px;
    color: var(--faint);
    flex-wrap: wrap;
  }
  .vault .note-meta .dot { opacity: 0.5; }
  .vault .note-meta .tags {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .vault .note-meta .tag { color: var(--mute); }

  /* Prose ─────────────────────────────────────────────────────────────── */
  .vault .prose {
    font-family: var(--display-font);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink);
  }
  .vault .prose > * + * { margin-top: 1.1em; }
  .vault .prose p { margin: 0; text-wrap: pretty; }

  .vault .prose h1,
  .vault .prose h2,
  .vault .prose h3,
  .vault .prose h4 {
    font-family: var(--display-font);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .vault .prose h1 { font-size: 28px; margin-top: 1.6em; }
  .vault .prose h2 { font-size: 23px; margin-top: 1.6em; }
  .vault .prose h3 { font-size: 19px; margin-top: 1.4em; }
  .vault .prose h4 { font-size: 16px; margin-top: 1.2em; }

  .vault .prose a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--hairline);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: text-decoration-color .15s, color .15s;
  }
  .vault .prose a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .vault .prose strong { font-weight: 600; }
  .vault .prose em { font-style: italic; }

  .vault .prose code {
    font-family: var(--mono-font);
    font-size: 0.88em;
    padding: 1px 5px;
    background: var(--surface);
    border: 0.5px solid var(--hairline);
    border-radius: 4px;
  }
  .vault .prose pre {
    font-family: var(--mono-font);
    font-size: 13px;
    line-height: 1.55;
    padding: 16px 18px;
    background: var(--surface);
    border: 0.5px solid var(--hairline);
    border-radius: 8px;
    overflow-x: auto;
    margin: 0;
  }
  .vault .prose pre code {
    padding: 0;
    background: transparent;
    border: 0;
    font-size: inherit;
  }

  .vault .prose blockquote {
    margin: 0;
    padding: 4px 0 4px 16px;
    border-left: 2px solid var(--accent);
    color: var(--mute);
    font-style: italic;
  }
  .vault .prose blockquote p { margin: 0; }
  .vault .prose blockquote > * + * { margin-top: 0.6em; }

  .vault .prose ul,
  .vault .prose ol {
    margin: 0;
    padding-left: 1.4em;
  }
  .vault .prose li { margin-top: 0.3em; }
  .vault .prose li::marker { color: var(--faint); }

  .vault .prose hr {
    border: 0;
    border-top: 0.5px solid var(--hairline);
    margin: 2em 0;
  }

  .vault .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .vault .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .vault .prose th,
  .vault .prose td {
    text-align: left;
    padding: 8px 12px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .vault .prose th {
    font-family: var(--mono-font);
    font-weight: 500;
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Callouts (rehype-callouts) ────────────────────────────────────────── */
  .vault .prose .callout {
    padding: 14px 16px;
    border: 0.5px solid var(--hairline);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    background: var(--surface);
    color: var(--ink);
  }
  .vault .prose .callout > * + * { margin-top: 0.6em; }
  .vault .prose .callout-title {
    font-family: var(--mono-font);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  @media (max-width: 880px) {
    .vault .note { padding: 12px 0 8px; }
    .vault .note-title { font-size: 32px; }
    .vault .prose { font-size: 16px; }
  }
</style>

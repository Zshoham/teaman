---
import { readdirSync, existsSync } from 'fs';
import { resolve } from 'path';
import Layout from '../../layouts/Layout.astro';

const slidesDir = resolve(process.cwd(), '../content/slides');
const base = import.meta.env.BASE_URL;

const decks = existsSync(slidesDir)
  ? readdirSync(slidesDir)
      .filter(f => f.endsWith('.md') && !f.startsWith('_'))
      .map(f => f.replace(/\.md$/, ''))
  : [];
---

<Layout title="Slides">
  <h1>Slides</h1>
  {decks.length === 0 && <p>No slide decks yet.</p>}
  <ul>
    {decks.map(deck => (
      <li>
        <a href={`${base}slides/${deck}/`} target="_blank" rel="noopener">
          {deck.replace(/-/g, ' ')}
        </a>
      </li>
    ))}
  </ul>
</Layout>
